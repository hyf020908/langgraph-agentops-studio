APP_NAME=LangGraph AgentOps Studio
LOG_LEVEL=INFO
OUTPUT_ROOT=runs
CHECKPOINT_MODE=memory
MAX_SEARCH_RESULTS=5
MAX_RETRIES=2
MAX_REVISIONS=2
RISK_THRESHOLD_FOR_HUMAN_REVIEW=0.68
DEFAULT_REVIEWER=governance-board
ENABLE_LANGSMITH=false
LANGSMITH_PROJECT=langgraph-agentops-studio

# LLM provider configuration
LLM_PROVIDER=openai_compatible
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200
LLM_TIMEOUT=60
LLM_EXTRA_HEADERS_JSON={}
LLM_EXTRA_KWARGS_JSON={}

# Embedding provider configuration
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT=60
EMBEDDING_EXTRA_HEADERS_JSON={}
EMBEDDING_EXTRA_KWARGS_JSON={}

# Vector DB / RAG configuration
VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=agentops_knowledge
QDRANT_LOCAL_PATH=.qdrant
VECTOR_DB_TIMEOUT=30
RAG_ENABLED=true
RAG_SOURCE_DIR=knowledge_base
RAG_TOP_K=4
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120
RAG_SCORE_THRESHOLD=

# Web grounding mode and providers
WEB_SEARCH_MODE=auto
WEB_SEARCH_PROVIDER=
WEB_READER_PROVIDER=
ENABLE_WEB_SEARCH=true
ENABLE_VECTOR_RAG=true
WEB_SEARCH_TOP_K=5
WEB_READER_TOP_K=3
EVIDENCE_MERGE_STRATEGY=score

# Tavily search
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_TOPIC=general
TAVILY_MAX_RESULTS=5
TAVILY_INCLUDE_RAW_CONTENT=false

# Jina Reader
JINA_API_KEY=
JINA_READER_BASE_URL=https://r.jina.ai/
JINA_READER_TIMEOUT=30
JINA_READER_JSON=false
JINA_READER_BYPASS_CACHE=false

# Exa search + contents
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai
EXA_SEARCH_TYPE=neural
EXA_MAX_RESULTS=5
EXA_USE_CONTENTS=true

# Governance policy thresholds
GOVERNANCE_OVERALL_RISK_THRESHOLD=0.65
GOVERNANCE_RECOMMENDATION_CONFIDENCE_THRESHOLD=0.62
GOVERNANCE_EVIDENCE_COMPLETENESS_THRESHOLD=0.55
GOVERNANCE_CONTRADICTION_SEVERITY_THRESHOLD=0.55
GOVERNANCE_UNRESOLVED_QUESTIONS_THRESHOLD=2
GOVERNANCE_HIGH_STAKES_TASK_CATEGORIES=architecture,security,finance
GOVERNANCE_MANUAL_APPROVAL_POLICY_BY_TASK_TYPE_JSON={}
